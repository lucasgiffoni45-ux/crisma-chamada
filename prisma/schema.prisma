generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- NextAuth ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Papel: "dono" | "coordenadora" | "formador" | "student"
  role          String    @default("student")
  // Organização (tenant) à qual coordenadora/formador pertence. Dono e aluno = null.
  orgId         String?
  org           Organizacao? @relation(fields: [orgId], references: [id])
  accounts      Account[]
  sessions      Session[]
  turmas        FormadorTurma[]
  attendances   Attendance[]
}

// Organização = unidade isolada (uma por coordenadora/paróquia). Garante que
// uma coordenadora não veja os dados de outra.
model Organizacao {
  id          String   @id @default(cuid())
  nome        String
  createdAt   DateTime @default(now())
  // Segmento de mercado — define o vocabulário do app (ver src/lib/segmentos.ts).
  // "catequese" | "escola" | "musica" | "artes-marciais" | ...
  segmento    String   @default("catequese")
  // Assinatura (SaaS)
  plano               String    @default("teste")  // teste | paroquia | diocese
  assinaturaStatus    String    @default("trial")  // trial | ativa | atrasada | cancelada
  trialFim            DateTime?
  periodoFim          DateTime?
  asaasCustomerId     String?
  asaasSubscriptionId String?
  // Inscrição pública (formulário aberto aos pais)
  inscricaoAberta     Boolean   @default(false)
  inscricaoToken      String?   @unique
  users       User[]
  turmas      Turma[]
  calendarios CalendarioSabado[]
  inscricoes  Inscricao[]
}

// Pré-inscrição feita pelos pais no formulário público; a coordenadora aprova
// (vira Crismando) ou recusa.
model Inscricao {
  id             String   @id @default(cuid())
  orgId          String
  org            Organizacao @relation(fields: [orgId], references: [id], onDelete: Cascade)
  nome           String
  dataNascimento String?
  contato        String?
  email          String?
  sacramentos    String?
  alergias       String?
  necessidades   String?
  nomePai        String?
  nomeMae        String?
  endereco       String?
  estadoCivil    String?
  serieEscolar   String?
  telefone       String?
  comunidade     String?
  comunidadeEncontros String?
  assinaturaResponsavel String?
  fotoBase64     String?  @db.Text // foto enviada pelo responsável (opcional)
  status         String   @default("pendente") // pendente | aprovada | recusada
  createdAt      DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domínio da Crisma ----------
model Turma {
  id        String          @id @default(cuid())
  nome      String
  createdAt DateTime        @default(now())
  orgId     String?
  org       Organizacao?    @relation(fields: [orgId], references: [id])
  formadores FormadorTurma[]
  crismandos Crismando[]
  encontros  Encontro[]
}

model FormadorTurma {
  id        String   @id @default(cuid())
  userId    String
  turmaId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  turma     Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([userId, turmaId])
}

model Crismando {
  id          String         @id @default(cuid())
  nome        String
  email       String?        @unique // opcional: coletado depois (login Google)
  contato     String?        // WhatsApp — visível ao formador
  idade       Int?
  dataNascimento String?     // texto livre (formatos variados) — formador
  sacramentos String?        // formador
  alergias    String?        // formador
  necessidades String?       // necessidades especiais — formador
  // Campos visíveis apenas para a coordenadora:
  nomePai     String?
  nomeMae     String?
  endereco    String?
  estadoCivil String?
  serieEscolar String?
  telefone    String?
  comunidade  String?        // comunidade que frequenta
  comunidadeEncontros String? // comunidade onde terá os encontros
  fotoBase64  String?        @db.Text // foto 3x4 (comprimida) — visível só à coordenação
  turmaId     String
  createdAt   DateTime       @default(now())
  turma       Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  anotacoes   AnotacaoAluno[]
}

model Encontro {
  id          String          @id @default(cuid())
  token       String          @unique @default(cuid())
  turmaId     String
  data        DateTime        // o sábado do encontro
  horario     String?
  tema        String?
  licaoDeCasa String?
  abertoEm    DateTime        @default(now())
  fechadoEm   DateTime?
  ativa       Boolean         @default(true)
  turma       Turma           @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  anotacoes   AnotacaoAluno[]
}

model Attendance {
  id          String     @id @default(cuid())
  crismandoId String
  encontroId  String
  marcadaEm   DateTime   @default(now())
  userId      String?
  crismando   Crismando  @relation(fields: [crismandoId], references: [id], onDelete: Cascade)
  encontro    Encontro   @relation(fields: [encontroId], references: [id], onDelete: Cascade)
  user        User?      @relation(fields: [userId], references: [id])

  @@unique([crismandoId, encontroId])
}

model AnotacaoAluno {
  id          String    @id @default(cuid())
  encontroId  String
  crismandoId String
  texto       String    // limitado a 50 caracteres na aplicação
  createdAt   DateTime  @default(now())
  encontro    Encontro  @relation(fields: [encontroId], references: [id], onDelete: Cascade)
  crismando   Crismando @relation(fields: [crismandoId], references: [id], onDelete: Cascade)

  @@unique([encontroId, crismandoId])
}

model CalendarioSabado {
  id         String   @id @default(cuid())
  data       DateTime // um sábado
  orgId      String?
  org        Organizacao? @relation(fields: [orgId], references: [id])
  temEncontro Boolean @default(true)
  recesso    Boolean  @default(false)
  horario    String?
  mensagem   String?  // recado da coordenadora, máx 50 caracteres na aplicação

  @@unique([orgId, data])
}

model LogAtividade {
  id        String   @id @default(cuid())
  userId    String?
  orgId     String?
  papel     String?
  acao      String
  alvo      String?
  createdAt DateTime @default(now())
}
